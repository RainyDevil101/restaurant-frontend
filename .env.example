# Frontend (Vite) — copy to .env for local development.
#
# IMPORTANT: VITE_* vars are baked in at BUILD time, not read at runtime.
# In production set them in your host's BUILD environment (Render Static Site /
# Vercel / Netlify) and re-build to change them — editing a file on the server
# does nothing.

# Base URL of the backend API: <origin> + /api
#   Dev:  http://localhost:3000/api
#   Prod: https://<your-backend-host>/api   (HTTPS, never localhost)
# The Socket.IO client derives the realtime URL from this (origin minus /api),
# so there is NO separate WebSocket variable to set.
VITE_API_URL=http://localhost:3000/api
